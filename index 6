<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no"/>
  <title>AR Menu | Sakura Dining</title>
  <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
  <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
  <style>
    :root {
      --ink:      #0C0A08;
      --paper:    #F7F0E6;
      --red:      #C0392B;
      --red2:     #E8523F;
      --gold:     #B8943A;
      --gold2:    #D4AF60;
      --ash:      #2A2420;
      --glass2:   rgba(247,240,230,0.06);
      --ff-disp:  'Shippori Mincho', serif;
      --ff-body:  'DM Sans', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      width: 100vw; min-height: 100vh; overflow-x: hidden;
      font-family: var(--ff-body); background: var(--ink); color: var(--paper);
      -webkit-tap-highlight-color: transparent;
    }
    body::before {
      content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 9999;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.78' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.028'/%3E%3C/svg%3E");
      opacity: 0.5;
    }
    .screen { display: none; }
    .screen.active { display: block; }

    /* NAV */
    .app-nav {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 500;
      padding: 10px 6px calc(10px + env(safe-area-inset-bottom));
      background: linear-gradient(0deg, rgba(8,6,4,0.98) 0%, rgba(12,10,8,0.95) 100%);
      border-top: 1px solid rgba(247,240,230,0.07); backdrop-filter: blur(20px);
      display: flex; justify-content: space-around; align-items: center;
    }
    .nav-tab { flex:1; display:flex; flex-direction:column; align-items:center; gap:4px; padding:8px 4px; border:none; background:none; cursor:pointer; }
    .nav-tab-icon { font-size: 20px; line-height: 1; }
    .nav-tab-label { font-size:9px; font-weight:400; letter-spacing:0.1em; color:rgba(247,240,230,0.3); text-transform:uppercase; transition:color 0.2s; }
    .nav-tab.active .nav-tab-label { color: var(--red); }
    .nav-tab-dot { width:4px; height:4px; border-radius:50%; background:var(--red); opacity:0; transition:opacity 0.2s; }
    .nav-tab.active .nav-tab-dot { opacity: 1; }

    /* 3D SCREEN */
    #screen3D { min-height:100vh; background:radial-gradient(ellipse 100% 50% at 50% 0%, rgba(42,36,32,0.8) 0%, #0C0A08 60%); }
    .screen-header { padding:52px 20px 16px; display:flex; align-items:flex-end; justify-content:space-between; }
    .screen-title { font-family:var(--ff-disp); font-size:30px; font-weight:600; color:var(--paper); line-height:1.1; }
    .screen-sub { font-size:11px; font-weight:300; color:rgba(247,240,230,0.35); margin-top:4px; letter-spacing:0.1em; }
    .screen-badge { font-size:9px; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:var(--red); background:rgba(192,57,43,0.12); border:1px solid rgba(192,57,43,0.25); border-radius:20px; padding:5px 10px; }
    .cat-strip { display:flex; gap:8px; padding:0 20px 16px; overflow-x:auto; scrollbar-width:none; }
    .cat-strip::-webkit-scrollbar { display:none; }
    .cat-pill { flex-shrink:0; padding:7px 16px; border-radius:20px; border:1px solid rgba(247,240,230,0.1); background:rgba(247,240,230,0.04); font-size:11px; font-weight:400; color:rgba(247,240,230,0.45); cursor:pointer; transition:all 0.18s; white-space:nowrap; }
    .cat-pill.active { background:var(--red); border-color:var(--red); color:#fff; }

    /* VIEWER */
    .viewer-wrap { position:relative; height:300px; margin:0 20px; border-radius:20px; overflow:hidden; background:linear-gradient(135deg,rgba(42,36,32,0.6),rgba(20,15,10,0.8)); border:1px solid rgba(247,240,230,0.07); }
    #dishViewer3D { width:100%; height:100%; --poster-color:transparent; background:transparent; }
    .viewer-overlay-tl { position:absolute; top:12px; left:14px; pointer-events:none; display:flex; align-items:center; gap:6px; }
    .viewer-dot { width:6px; height:6px; border-radius:50%; background:var(--red); animation:blink 2s ease infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
    .viewer-live { font-size:9px; font-weight:500; letter-spacing:0.16em; text-transform:uppercase; color:rgba(247,240,230,0.5); }
    .viewer-hint { position:absolute; bottom:72px; left:50%; transform:translateX(-50%); font-size:10px; font-weight:300; letter-spacing:0.18em; text-transform:uppercase; color:rgba(247,240,230,0.35); white-space:nowrap; pointer-events:none; }

    /* TAP TO PLACE AR BUTTON */
    .ar-place-btn {
      position: absolute;
      bottom: 14px; left: 50%; transform: translateX(-50%);
      display: none; align-items: center; gap: 10px;
      background: linear-gradient(135deg, var(--red) 0%, #E8523F 100%);
      border: none; border-radius: 50px;
      padding: 13px 24px;
      font-family: var(--ff-body); font-size: 13px; font-weight: 500;
      color: #fff; letter-spacing: 0.04em;
      cursor: pointer; white-space: nowrap;
      box-shadow: 0 4px 24px rgba(192,57,43,0.55), 0 0 0 0 rgba(192,57,43,0.4);
      animation: arPulse 2.4s ease-in-out infinite;
      z-index: 10;
    }
    .ar-place-btn.visible { display: flex; }
    @keyframes arPulse {
      0%,100% { box-shadow: 0 4px 24px rgba(192,57,43,0.55), 0 0 0 0 rgba(192,57,43,0.35); }
      50%      { box-shadow: 0 4px 32px rgba(192,57,43,0.7), 0 0 0 10px rgba(192,57,43,0); }
    }
    .ar-place-btn:active { transform: translateX(-50%) scale(0.95); animation: none; }
    .ar-tap-icon { width: 22px; height: 22px; position: relative; flex-shrink: 0; }
    .ar-tap-icon svg { width: 22px; height: 22px; }
    .ar-tap-ring {
      position: absolute; inset: -4px; border-radius: 50%;
      border: 1.5px solid rgba(255,255,255,0.6);
      animation: tapRing 1.6s ease-out infinite;
    }
    @keyframes tapRing {
      0%   { opacity: 0.8; transform: scale(0.6); }
      100% { opacity: 0;   transform: scale(1.6); }
    }
    .ar-btn-text { display: flex; flex-direction: column; gap: 1px; }
    .ar-btn-main { font-size: 13px; font-weight: 500; line-height: 1.2; }
    .ar-btn-sub  { font-size: 9px; font-weight: 300; opacity: 0.7; letter-spacing: 0.12em; text-transform: uppercase; }

    /* AR launching overlay */
    #arLaunchOverlay {
      position: absolute; inset: 0; z-index: 20;
      background: rgba(12,10,8,0.82); backdrop-filter: blur(4px);
      display: none; flex-direction: column; align-items: center; justify-content: center; gap: 14px;
      border-radius: 20px;
    }
    #arLaunchOverlay.show { display: flex; }
    .ar-launch-ring {
      width: 56px; height: 56px; border-radius: 50%;
      border: 2px solid rgba(192,57,43,0.25); border-top-color: var(--red);
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .ar-launch-text { font-size: 12px; font-weight: 300; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(247,240,230,0.5); }
    .ar-launch-sub  { font-size: 10px; font-weight: 300; color: rgba(247,240,230,0.3); text-align: center; line-height: 1.5; padding: 0 24px; }

    /* no-AR fallback toast */
    #arUnsupportedMsg {
      position: absolute; bottom: 14px; left: 14px; right: 14px;
      background: rgba(42,36,32,0.95); border: 1px solid rgba(247,240,230,0.1);
      border-radius: 12px; padding: 10px 14px;
      font-size: 10px; font-weight: 300; letter-spacing: 0.1em; color: rgba(247,240,230,0.45);
      display: none; text-align: center; z-index: 15;
    }
    #arUnsupportedMsg.show { display: block; }

    .dish-detail { margin:14px 20px 0; background:var(--glass2); border:1px solid rgba(247,240,230,0.07); border-radius:18px; padding:16px; backdrop-filter:blur(12px); display:flex; align-items:flex-start; gap:14px; }
    .dish-detail-emoji { font-size:38px; flex-shrink:0; }
    .dish-detail-name { font-family:var(--ff-disp); font-size:20px; font-weight:500; color:var(--paper); }
    .dish-detail-desc { font-size:11.5px; font-weight:300; color:rgba(247,240,230,0.45); line-height:1.6; margin:4px 0 8px; }
    .dish-detail-row { display:flex; align-items:center; justify-content:space-between; }
    .dish-detail-price { font-family:var(--ff-disp); font-size:20px; color:var(--gold2); }
    .dish-tag { font-size:9px; letter-spacing:0.1em; padding:3px 8px; border-radius:10px; font-weight:400; text-transform:uppercase; }
    .tag-popular { background:rgba(184,148,58,0.12); color:var(--gold2); border:1px solid rgba(184,148,58,0.2); }
    .dish-row-title { font-size:10px; font-weight:400; letter-spacing:0.2em; text-transform:uppercase; color:rgba(247,240,230,0.25); padding:18px 20px 10px; }
    .dish-chips-scroll { display:flex; gap:10px; padding:0 20px 100px; overflow-x:auto; scrollbar-width:none; }
    .dish-chips-scroll::-webkit-scrollbar { display:none; }
    .dish-chip3d { flex-shrink:0; width:80px; cursor:pointer; transition:transform 0.15s; }
    .dish-chip3d:active { transform:scale(0.92); }
    .dish-chip3d-img { width:80px; height:80px; border-radius:16px; background:rgba(247,240,230,0.05); border:1.5px solid rgba(247,240,230,0.08); display:flex; align-items:center; justify-content:center; font-size:30px; margin-bottom:6px; transition:all 0.2s; }
    .dish-chip3d.active .dish-chip3d-img { border-color:var(--red); background:rgba(192,57,43,0.1); }
    .dish-chip3d-name { font-size:9.5px; font-weight:300; color:rgba(247,240,230,0.4); text-align:center; line-height:1.3; }
    .dish-chip3d.active .dish-chip3d-name { color:var(--paper); }
    .no-model-badge { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:11px; font-weight:300; letter-spacing:0.14em; text-transform:uppercase; color:rgba(247,240,230,0.25); white-space:nowrap; pointer-events:none; }

    /* ORDER SCREEN */
    #screenOrder { min-height:100vh; background:radial-gradient(ellipse 80% 40% at 80% 0%, rgba(184,148,58,0.08) 0%, transparent 55%), #0C0A08; }
    .table-id-bar { margin:0 20px 16px; background:rgba(184,148,58,0.08); border:1px solid rgba(184,148,58,0.18); border-radius:12px; padding:11px 16px; display:flex; align-items:center; justify-content:space-between; }
    .table-id-left { display:flex; align-items:center; gap:10px; }
    .table-num-badge { width:36px; height:36px; border-radius:10px; background:rgba(184,148,58,0.15); border:1px solid rgba(184,148,58,0.25); display:flex; align-items:center; justify-content:center; font-family:var(--ff-disp); font-size:17px; font-weight:600; color:var(--gold2); }
    .table-id-info .t-label { font-size:9px; letter-spacing:0.16em; text-transform:uppercase; color:rgba(247,240,230,0.3); }
    .table-id-info .t-val   { font-size:13px; font-weight:400; color:var(--paper); margin-top:1px; }
    .table-scan-btn { font-size:10px; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:var(--gold2); background:none; border:1px solid rgba(184,148,58,0.25); border-radius:8px; padding:7px 12px; cursor:pointer; }
    .order-section-title { font-family:var(--ff-disp); font-size:18px; font-weight:500; color:var(--paper); padding:0 20px 12px; display:flex; align-items:center; justify-content:space-between; }
    .order-section-title span { font-family:var(--ff-body); font-size:10px; font-weight:300; color:rgba(247,240,230,0.3); }
    .order-grid { display:flex; flex-direction:column; gap:10px; padding:0 20px; }
    .order-item { background:var(--glass2); border:1px solid rgba(247,240,230,0.07); border-radius:16px; padding:14px; display:flex; align-items:center; gap:14px; }
    .order-item-emoji { font-size:32px; flex-shrink:0; }
    .order-item-info { flex:1; min-width:0; }
    .order-item-name { font-family:var(--ff-disp); font-size:16px; font-weight:500; color:var(--paper); }
    .order-item-desc { font-size:10.5px; font-weight:300; color:rgba(247,240,230,0.35); line-height:1.4; margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .order-item-price { font-size:14px; font-weight:400; color:var(--gold2); font-family:var(--ff-disp); margin-top:4px; }
    .qty-control { display:flex; flex-direction:column; align-items:center; gap:6px; flex-shrink:0; }
    .qty-btn { width:30px; height:30px; border-radius:10px; border:1px solid rgba(247,240,230,0.12); background:rgba(247,240,230,0.05); color:var(--paper); font-size:18px; line-height:1; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:background 0.15s; }
    .qty-btn:active { background:rgba(192,57,43,0.2); }
    .qty-num { font-size:16px; font-weight:500; color:var(--paper); min-width:20px; text-align:center; }
    .cart-bar { position:fixed; bottom:68px; left:16px; right:16px; z-index:400; background:var(--red); border-radius:16px; padding:14px 18px; display:none; align-items:center; justify-content:space-between; box-shadow:0 8px 32px rgba(192,57,43,0.5); cursor:pointer; transition:transform 0.15s; }
    .cart-bar:active { transform:scale(0.98); }
    .cart-bar.visible { display:flex; }
    .cart-bar-left { display:flex; align-items:center; gap:10px; }
    .cart-count-badge { width:28px; height:28px; border-radius:8px; background:rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:600; color:#fff; }
    .cart-label { font-size:14px; font-weight:500; color:#fff; }
    .cart-total { font-family:var(--ff-disp); font-size:18px; color:#fff; }

    /* MENU SCREEN */
    #screenMenu { min-height:100vh; background:#0C0A08; padding-bottom:100px; }
    .menu-hero { position:relative; height:180px; overflow:hidden; background:linear-gradient(135deg,rgba(42,20,10,1) 0%,rgba(12,10,8,1) 100%); display:flex; align-items:flex-end; padding:20px; }
    .menu-hero-bg { position:absolute; inset:0; background:radial-gradient(circle at 20% 50%,rgba(192,57,43,0.25) 0%,transparent 40%),radial-gradient(circle at 80% 30%,rgba(184,148,58,0.15) 0%,transparent 35%); }
    .menu-hero-pattern { position:absolute; right:0; top:0; bottom:0; width:200px; opacity:0.06; background-image:repeating-linear-gradient(45deg,var(--paper) 0,var(--paper) 1px,transparent 0,transparent 50%); background-size:14px 14px; }
    .menu-hero-content { position:relative; z-index:2; }
    .menu-hero-tag { font-size:9px; letter-spacing:0.22em; text-transform:uppercase; color:rgba(192,57,43,0.8); margin-bottom:6px; }
    .menu-hero-title { font-family:var(--ff-disp); font-size:34px; font-weight:600; color:var(--paper); line-height:1.05; }
    .menu-hero-sub { font-size:11px; font-weight:300; color:rgba(247,240,230,0.4); margin-top:6px; }
    .menu-section { padding:24px 20px 0; }
    .menu-section-head { display:flex; align-items:center; gap:12px; margin-bottom:14px; }
    .section-line { flex:1; height:1px; background:rgba(247,240,230,0.07); }
    .section-name { font-family:var(--ff-disp); font-size:13px; font-weight:500; font-style:italic; color:var(--gold2); letter-spacing:0.06em; white-space:nowrap; }
    .section-jp { font-size:11px; color:rgba(247,240,230,0.2); margin-left:6px; }
    .menu-card { background:var(--glass2); border:1px solid rgba(247,240,230,0.06); border-radius:16px; padding:14px; margin-bottom:10px; display:flex; gap:14px; position:relative; overflow:hidden; }
    .menu-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:3px; background:transparent; }
    .menu-card.featured::before { background:var(--red); }
    .menu-card-emoji { font-size:36px; flex-shrink:0; }
    .menu-card-body { flex:1; min-width:0; }
    .menu-card-name { font-family:var(--ff-disp); font-size:17px; font-weight:500; color:var(--paper); }
    .menu-card-jp   { font-size:10px; color:rgba(247,240,230,0.2); margin:1px 0 5px; letter-spacing:0.08em; }
    .menu-card-desc { font-size:11px; font-weight:300; color:rgba(247,240,230,0.4); line-height:1.55; margin-bottom:8px; }
    .menu-card-foot { display:flex; align-items:center; justify-content:space-between; }
    .menu-card-price { font-family:var(--ff-disp); font-size:17px; color:var(--gold2); }
    .menu-card-pills { display:flex; gap:5px; }
    .menu-pill { font-size:8.5px; letter-spacing:0.08em; text-transform:uppercase; padding:3px 7px; border-radius:8px; font-weight:400; }
    .pill-veg  { background:rgba(46,125,50,0.12);  color:#A5D6A7; border:1px solid rgba(46,125,50,0.2); }
    .pill-chef { background:rgba(184,148,58,0.1);  color:var(--gold2); border:1px solid rgba(184,148,58,0.18); }
    .pill-new  { background:rgba(30,100,180,0.1);  color:#90CAF9;  border:1px solid rgba(30,100,180,0.18); }
    .add-circle { width:34px; height:34px; border-radius:50%; background:var(--red); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:22px; color:#fff; font-weight:300; line-height:1; box-shadow:0 4px 16px rgba(192,57,43,0.4); transition:transform 0.15s; }
    .add-circle:active { transform:scale(0.9); }
    .ar-mini-btn { font-size:8.5px; letter-spacing:0.1em; text-transform:uppercase; color:rgba(247,240,230,0.3); background:rgba(247,240,230,0.05); border:1px solid rgba(247,240,230,0.08); border-radius:8px; padding:4px 8px; cursor:pointer; white-space:nowrap; }
    .featured-banner { display:inline-flex; align-items:center; gap:5px; font-size:8.5px; letter-spacing:0.12em; text-transform:uppercase; color:var(--red); margin-bottom:3px; }

    /* CART MODAL */
    #cartModal { position:fixed; inset:0; z-index:800; display:none; background:rgba(0,0,0,0.7); backdrop-filter:blur(6px); align-items:flex-end; }
    #cartModal.open { display:flex; }
    .cart-sheet { width:100%; background:#1A1210; border-radius:28px 28px 0 0; border-top:1px solid rgba(247,240,230,0.08); padding:12px 0 calc(28px + env(safe-area-inset-bottom)); max-height:80vh; overflow-y:auto; }
    .cart-handle { width:32px; height:3px; background:rgba(255,255,255,0.08); border-radius:2px; margin:0 auto 20px; }
    .cart-title { font-family:var(--ff-disp); font-size:24px; font-weight:600; color:var(--paper); padding:0 20px 16px; }
    .cart-items { padding:0 20px; }
    .cart-row { display:flex; align-items:center; gap:12px; padding:12px 0; border-bottom:1px solid rgba(247,240,230,0.06); }
    .cart-row-emoji { font-size:28px; }
    .cart-row-name { font-family:var(--ff-disp); font-size:15px; color:var(--paper); flex:1; }
    .cart-row-qty { font-size:13px; font-weight:300; color:rgba(247,240,230,0.4); }
    .cart-row-price { font-family:var(--ff-disp); font-size:15px; color:var(--gold2); }
    .cart-divider { height:1px; background:rgba(247,240,230,0.06); margin:16px 20px; }
    .cart-total-row { display:flex; justify-content:space-between; align-items:center; padding:0 20px 20px; }
    .cart-total-label { font-size:13px; font-weight:300; color:rgba(247,240,230,0.5); }
    .cart-total-val { font-family:var(--ff-disp); font-size:24px; font-weight:600; color:var(--paper); }
    .place-order-btn { width:calc(100% - 40px); margin:0 20px; padding:17px; background:var(--red); border:none; border-radius:14px; font-family:var(--ff-body); font-size:15px; font-weight:500; color:#fff; letter-spacing:0.05em; cursor:pointer; box-shadow:0 6px 24px rgba(192,57,43,0.45); }

    /* TOAST */
    #toast { position:fixed; top:-60px; left:50%; transform:translateX(-50%); z-index:900; background:rgba(46,125,50,0.9); backdrop-filter:blur(12px); border:1px solid rgba(129,199,132,0.3); border-radius:50px; padding:10px 20px; font-size:13px; font-weight:500; color:#A5D6A7; white-space:nowrap; transition:top 0.35s cubic-bezier(0.34,1.56,0.64,1); pointer-events:none; }
    #toast.show { top:52px; }

    /* LOADER */
    #modelLoader3d { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); display:none; flex-direction:column; align-items:center; gap:10px; pointer-events:none; }
    .loader-ring3d { width:36px; height:36px; border:1.5px solid rgba(192,57,43,0.15); border-top-color:var(--red); border-radius:50%; animation:spin 0.7s linear infinite; }
    .loader-text3d { font-size:9px; letter-spacing:0.2em; text-transform:uppercase; color:rgba(247,240,230,0.3); }

    /* SPLASH */
