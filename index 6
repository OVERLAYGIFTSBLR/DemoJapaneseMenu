  const el = document.getElementById('sheetBadge');
  if (el) { el.textContent = msg; el.style.display = 'block'; }
}

/* ══════════════════════════════════════
   AR LAUNCH
══════════════════════════════════════ */
function launchAR() {
  const viewer  = document.getElementById('dishViewer3D');
  const overlay = document.getElementById('arLaunchOverlay');
  const unsup   = document.getElementById('arUnsupportedMsg');

  if (!viewer || !viewer.src) {
    unsup.classList.add('show');
    setTimeout(() => unsup.classList.remove('show'), 3000);
    return;
  }

  overlay.classList.add('show');

  viewer.activateAR()
    .then(() => {
      overlay.classList.remove('show');
    })
    .catch(() => {
      overlay.classList.remove('show');
      unsup.classList.add('show');
      setTimeout(() => unsup.classList.remove('show'), 3000);
    });
}

document.addEventListener('DOMContentLoaded', () => {
  const viewer = document.getElementById('dishViewer3D');
  if (!viewer) return;

  viewer.addEventListener('ar-status', (e) => {
    const overlay = document.getElementById('arLaunchOverlay');
    if (e.detail.status === 'failed') {
      overlay.classList.remove('show');
      const unsup = document.getElementById('arUnsupportedMsg');
      unsup.classList.add('show');
      setTimeout(() => unsup.classList.remove('show'), 3000);
    }
    if (e.detail.status === 'session-started') {
      document.getElementById('arLaunchOverlay').classList.remove('show');
    }
  });
});

/* ══════════════════════════════════════
   GOOGLE SHEETS FETCH
   Reads: id, name, jp_name, category,
   description, price, emoji, veg,
   chef_pick, new, available, scale, glb_url
══════════════════════════════════════ */
async function fetchMenuFromSheet() {
  showSheetLoader(true);
  try {
    const res   = await fetch(SHEET_URL);
    const text  = await res.text();
    const match = text.match(/google\.visualization\.Query\.setResponse\(([\s\S]*?)\);/);
    if (!match) throw new Error('Bad sheet response');
    const json = JSON.parse(match[1]);
    const cols = json.table.cols.map(c => c.label.toLowerCase().trim());
    const get  = (row, col) => {
      const idx = cols.indexOf(col);
      return (idx >= 0 && row.c[idx] && row.c[idx].v != null) ? String(row.c[idx].v).trim() : '';
    };
    menuItems = json.table.rows
      .filter(r => r && r.c)
      .map((r, i) => ({
        id:          get(r,'id')          || 'item_'+i,
        name:        get(r,'name'),
        jp:          get(r,'jp_name'),
        category:    get(r,'category').toLowerCase(),
        description: get(r,'description'),
        price:       parseInt(get(r,'price'))        || 0,
        emoji:       get(r,'emoji')                  || '🍽️',
        veg:         get(r,'veg').toLowerCase()       === 'yes',
        chef_pick:   get(r,'chef_pick').toLowerCase() === 'yes',
        new:         get(r,'new').toLowerCase()        === 'yes',
        available:   get(r,'available').toLowerCase()  !== 'no',
        scale:       parseFloat(get(r,'scale'))        || 1.0,
        glb_url:     get(r,'glb_url'),
      }))
      .filter(item => item.name);
    console.log('✅ Sheet loaded:', menuItems.length, 'items');
    showSheetBadge('✅ Live from Google Sheet');
  } catch(err) {
    console.warn('Sheet failed, using fallback:', err.message);
    menuItems = FALLBACK;
    showSheetBadge('⚠️ Using offline menu');
  }
  showSheetLoader(false);
  initMenuScreens();
}

/* ══════════════════════════════════════
   INIT
══════════════════════════════════════ */
function initMenuScreens() {
  currentDish3D = getDishes3D()[0] || menuItems[0] || null;
  buildDishChips3D(currentCat3D);
  if (currentDish3D) selectDish3D(currentDish3D, null);
  buildOrderGrid(currentCatOrder);
  buildMenu();
}

/* ══════════════════════════════════════
   NAVIGATION
══════════════════════════════════════ */
function goTo(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.getElementById('appNav').style.display = 'flex';
  ['navTab3D','navTabOrder','navTabMenu'].forEach(t => document.getElementById(t).classList.remove('active'));
  if (id === 'screen3D')    document.getElementById('navTab3D').classList.add('active');
  if (id === 'screenOrder') document.getElementById('navTabOrder').classList.add('active');
  if (id === 'screenMenu')  document.getElementById('navTabMenu').classList.add('active');
  window.scrollTo(0, 0);
}

/* ══════════════════════════════════════
   3D VIEWER
   Scale from Google Sheet controls:
   1. model-viewer "scale" attribute (GLB mesh scale)
   2. camera orbit radius (locks zoom distance)
   3. min/max-camera-orbit (prevents user zoom)
   Pinch-to-zoom is fully disabled via
   disable-zoom + touch-action="none" on
   the model-viewer element.
══════════════════════════════════════ */
function buildDishChips3D(cat) {
  const scroll   = document.getElementById('dishScroll3D');
  scroll.innerHTML = '';
  const all3D    = getDishes3D();
  const filtered = cat === 'all' ? all3D : all3D.filter(d => d.category === cat);
  if (!filtered.length) {
    scroll.innerHTML = '<div style="color:rgba(247,240,230,0.25);font-size:11px;padding:10px 0;">No 3D models in this category yet</div>';
    return;
  }
  filtered.forEach(dish => {
    const chip = document.createElement('div');
    chip.className = 'dish-chip3d' + (currentDish3D && dish.id === currentDish3D.id ? ' active' : '');
    chip.innerHTML = `<div class="dish-chip3d-img">${dish.emoji}</div><div class="dish-chip3d-name">${dish.name.split(' ').slice(0,2).join(' ')}</div>`;
    chip.onclick   = () => selectDish3D(dish, chip);
    scroll.appendChild(chip);
  });
}

function applyDishScale(viewer, scale) {
  /* scale: value from Google Sheet "scale" column.
     1.0 = default size. 2.0 = twice as large in AR.
     Camera radius is inversely proportional so the
     model always fills the 3D preview nicely. */
  const s = scale || 1.0;

  /* Apply scale to the 3D mesh itself */
  viewer.setAttribute('scale', `${s} ${s} ${s}`);

  /* Lock camera distance so zoom is fixed at the
     right distance for this model's scale.
     Larger model (s>1) = camera closer (smaller radius). */
  const radius = (2.5 / s).toFixed(3) + 'm';
  viewer.setAttribute('camera-orbit',     `0deg 75deg ${radius}`);
  viewer.setAttribute('min-camera-orbit', `auto auto ${radius}`);
  viewer.setAttribute('max-camera-orbit', `auto auto ${radius}`);
}

function selectDish3D(dish, chipEl) {
  const viewer = document.getElementById('dishViewer3D');
  const loader = document.getElementById('modelLoader3d');
  const noMod  = document.getElementById('noModel3d');
  const hint   = document.getElementById('viewerHint');
  const arBtn  = document.getElementById('arPlaceBtn');

  currentDish3D = dish;

  // Update info panel
  document.getElementById('ddEmoji').textContent = dish.emoji;
  document.getElementById('ddName').textContent  = dish.name;
  document.getElementById('ddDesc').textContent  = dish.description;
  document.getElementById('ddPrice').textContent = '₹ ' + dish.price;

  // Update chip active state
  document.querySelectorAll('.dish-chip3d').forEach(c => c.classList.remove('active'));
  if (chipEl) chipEl.classList.add('active');

  if (dish.glb_url) {
    if (loader) loader.style.display = 'flex';
    if (noMod)  noMod.style.display  = 'none';
    if (arBtn)  arBtn.classList.remove('visible');
    if (hint)   hint.textContent = 'Loading model…';

    /* Apply scale BEFORE loading so the model renders
       at the correct size on first frame */
    applyDishScale(viewer, dish.scale);

    /* Safe model swap: clear src first, set on next frame
       to avoid stale load events from previous model */
    viewer.src = '';
    requestAnimationFrame(() => {
      viewer.src = dish.glb_url;
    });

    /* After load: hide loader, update hint, show AR button
       only if this device actually supports AR */
    viewer.addEventListener('load', function onModelLoad() {
      viewer.removeEventListener('load', onModelLoad);
      if (loader) loader.style.display = 'none';
      if (hint)   hint.textContent = 'Drag to rotate';
      if (arBtn)  arBtn.classList.toggle('visible', !!viewer.canActivateAR);
    });

  } else {
    viewer.src = '';
    viewer.removeAttribute('scale');
    /* Reset camera to defaults when no model */
    viewer.setAttribute('camera-orbit',     '0deg 75deg 2.5m');
    viewer.setAttribute('min-camera-orbit', 'auto auto 2.5m');
    viewer.setAttribute('max-camera-orbit', 'auto auto 2.5m');
    if (loader) loader.style.display = 'none';
    if (noMod)  noMod.style.display  = 'block';
    if (arBtn)  arBtn.classList.remove('visible');
    if (hint)   hint.textContent = 'No 3D preview available';
  }
}

function filterCat3D(cat, el) {
  currentCat3D = cat;
  document.querySelectorAll('#catStrip3D .cat-pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  buildDishChips3D(cat);
}

/* ══════════════════════════════════════
   ORDER GRID
══════════════════════════════════════ */
function buildOrderGrid(cat) {
  const grid     = document.getElementById('orderGrid');
  grid.innerHTML = '';
  const filtered = cat === 'all' ? menuItems : menuItems.filter(i => i.category === cat);
  document.getElementById('orderCountLabel').textContent = filtered.length + ' items';
  filtered.forEach(item => {
    const qty     = cart[item.id] || 0;
    const unavail = !item.available;
    const row     = document.createElement('div');
    row.className = 'order-item';
    row.id        = 'orderRow_' + item.id;
    row.style.opacity = unavail ? '0.5' : '1';
    row.innerHTML = `
      <div class="order-item-emoji">${item.emoji}</div>
      <div class="order-item-info">
        <div class="order-item-name">${item.name}</div>
        <div class="order-item-desc">${item.description}</div>
        <div class="order-item-price" style="display:flex;align-items:center;gap:8px;">
          ₹ ${item.price}
          ${unavail ? '<span style="font-size:9px;background:rgba(192,57,43,0.15);color:#EF9A9A;border:1px solid rgba(192,57,43,0.25);border-radius:8px;padding:2px 8px;">Not Available</span>' : ''}
        </div>
      </div>
      <div class="qty-control">
        <button class="qty-btn" onclick="changeQty('${item.id}',1)" ${unavail?'disabled style="opacity:0.3"':''}>+</button>
        <div class="qty-num" id="qty_${item.id}">${qty||'—'}</div>
        <button class="qty-btn" onclick="changeQty('${item.id}',-1)" ${unavail?'disabled style="opacity:0.3"':''}>−</button>
      </div>`;
    grid.appendChild(row);
  });
}

function filterOrder(cat, el) {
  currentCatOrder = cat;
  document.querySelectorAll('#catStripOrder .cat-pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  buildOrderGrid(cat);
}

function changeQty(id, delta) {
  const item = menuItems.find(i => i.id === id);
  if (!item || !item.available) return;
  cart[id] = Math.max(0, (cart[id] || 0) + delta);
  if (!cart[id]) delete cart[id];
  const el = document.getElementById('qty_' + id);
  if (el) el.textContent = cart[id] || '—';
  updateCartBar();
}

function updateCartBar() {
  const count = Object.values(cart).reduce((a,b) => a+b, 0);
  const total = Object.entries(cart).reduce((s,[id,q]) => {
    const it = menuItems.find(i => i.id === id);
    return s + (it ? it.price * q : 0);
  }, 0);
  document.getElementById('cartCountBadge').textContent = count;
  document.getElementById('cartTotalBar').textContent   = '₹ ' + total.toLocaleString('en-IN');
  document.getElementById('cartBar').classList.toggle('visible', count > 0);
}

/* ══════════════════════════════════════
   CART MODAL
══════════════════════════════════════ */
function openCart() {
  const items = document.getElementById('cartItems');
  items.innerHTML = '';
  let sum = 0;
  Object.entries(cart).forEach(([id, qty]) => {
    const item = menuItems.find(i => i.id === id);
    if (!item) return;
    const sub = item.price * qty; sum += sub;
    items.innerHTML += `<div class="cart-row">
      <div class="cart-row-emoji">${item.emoji}</div>
      <div class="cart-row-name">${item.name}</div>
      <div class="cart-row-qty">× ${qty}</div>
      <div class="cart-row-price">₹ ${sub.toLocaleString('en-IN')}</div>
    </div>`;
  });
  document.getElementById('cartTotalModal').textContent = '₹ ' + sum.toLocaleString('en-IN');
  document.getElementById('cartModal').classList.add('open');
}
document.getElementById('cartModal').addEventListener('click', function(e) {
  if (e.target === this) this.classList.remove('open');
});

/* ══════════════════════════════════════
   FULL MENU BUILD
══════════════════════════════════════ */
function buildMenu() {
  const cats = [
    { key:'starter', id:'menuStarters' },
    { key:'sushi',   id:'menuSushi'    },
    { key:'ramen',   id:'menuRamen'    },
    { key:'rice',    id:'menuRice'     },
    { key:'drinks',  id:'menuDrinks'   },
  ];
  const pillLabel = { veg:'Veg', chef:"Chef's Pick", new:'New' };
  const pillClass = { veg:'pill-veg', chef:'pill-chef', new:'pill-new' };

  cats.forEach(({ key, id }) => {
    const cont = document.getElementById(id);
    const head = document.getElementById('sectionHead_' + key);
    if (!cont) return;
    cont.innerHTML = '';
    const items = menuItems.filter(i => i.category === key);
    if (head) head.style.display = items.length ? 'flex' : 'none';
    items.forEach(item => {
      const unavail = !item.available;
      const pills   = getPills(item).map(p => `<span class="menu-pill ${pillClass[p]}">${pillLabel[p]}</span>`).join('');
      cont.innerHTML += `
        <div class="menu-card ${item.chef_pick?'featured':''}" style="${unavail?'opacity:0.55;':''}">
          <div style="display:flex;flex-direction:column;justify-content:space-between;flex:1;gap:10px;">
            <div style="display:flex;gap:12px;align-items:flex-start;">
              <div class="menu-card-emoji">${item.emoji}</div>
              <div class="menu-card-body">
                ${item.chef_pick?'<div class="featured-banner">★ Chef Recommends</div>':''}
                <div class="menu-card-name">${item.name}</div>
                <div class="menu-card-jp">${item.jp||''}</div>
                <div class="menu-card-desc">${item.description}</div>
                ${unavail?'<div style="font-size:10px;color:#EF9A9A;margin-top:3px;">❌ Not Available Today</div>':''}
              </div>
            </div>
            <div class="menu-card-foot">
              <div>
                <div class="menu-card-price">₹ ${item.price}</div>
                <div class="menu-card-pills" style="margin-top:5px;">${pills}</div>
              </div>
              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:7px;">
                ${unavail
                  ? `<div style="width:34px;height:34px;border-radius:50%;background:rgba(247,240,230,0.06);display:flex;align-items:center;justify-content:center;font-size:16px;">✕</div>`
                  : `<button class="add-circle" onclick="addFromMenu('${item.id}')">+</button>`}
                ${item.glb_url
                  ? `<button class="ar-mini-btn" onclick="goTo('screen3D')">3D View 🥢</button>`
                  : `<button class="ar-mini-btn" style="opacity:0.3;pointer-events:none;">No 3D</button>`}
              </div>
            </div>
          </div>
        </div>`;
    });
  });
}

function addFromMenu(id) {
  const item = menuItems.find(i => i.id === id);
  if (!item || !item.available) return;
  cart[id] = (cart[id] || 0) + 1;
  updateCartBar();
  showToast(item.emoji + ' ' + item.name + ' added to order');
}

/* ══════════════════════════════════════
   WHATSAPP KOT
══════════════════════════════════════ */
function generateOrderId() { return '#ORD-' + Math.floor(1000 + Math.random()*9000); }

function buildKOTMessage(orderId, snap, note, total) {
  const now  = new Date();
  const time = now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:true});
  const date = now.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
  let lines  = '';
  snap.forEach(({item,qty}) => {
    lines += item.emoji+' '+item.name.padEnd(18)+' x'+qty+'   ₹'+(item.price*qty).toLocaleString('en-IN')+'\n';
  });
  return (
    '🍽️ *NEW ORDER — KOT*\n━━━━━━━━━━━━━━━━━━━━\n'+
    '*Table  :* '+TABLE_NUMBER+'\n'+
    '*Seat   :* '+TABLE_INFO+'\n'+
    '*Order  :* '+orderId+'\n'+
    '*Time   :* '+time+', '+date+'\n'+
    '━━━━━━━━━━━━━━━━━━━━\n'+lines+
    '━━━━━━━━━━━━━━━━━━━━\n'+
    '*TOTAL  :* ₹'+total.toLocaleString('en-IN')+'\n'+
    '━━━━━━━━━━━━━━━━━━━━'+
    (note?'\n📝 *Note:* '+note:'')+
    '\n_Sent via Sakura AR Menu_'
  );
}

function placeOrder() {
  const snap = []; let total = 0;
  Object.entries(cart).forEach(([id,qty]) => {
    const item = menuItems.find(i => i.id === id);
    if (!item) return;
    snap.push({item,qty}); total += item.price*qty;
  });
  if (!snap.length) return;

  const orderId = generateOrderId();
  const note    = document.getElementById('specialNote').value.trim();
  const msg     = buildKOTMessage(orderId, snap, note, total);

  document.getElementById('cartModal').classList.remove('open');
  const successEl = document.getElementById('orderSuccess');
  successEl.style.display = 'flex';
  document.getElementById('successOrderId').textContent = orderId+' · Table '+TABLE_NUMBER;

  let preview = '';
  snap.forEach(({item,qty}) => {
    preview += item.emoji+' '+item.name+' × '+qty+'   ₹'+(item.price*qty).toLocaleString('en-IN')+'\n';
  });
  preview += '\nTotal: ₹'+total.toLocaleString('en-IN');
  if (note) preview += '\n📝 '+note;
  document.getElementById('kotPreview').textContent = preview;

  setTimeout(() => window.open('https://wa.me/'+KITCHEN_WHATSAPP+'?text='+encodeURIComponent(msg),'_blank'), 600);
  if (BILLING_WHATSAPP !== KITCHEN_WHATSAPP) {
    setTimeout(() => window.open('https://wa.me/'+BILLING_WHATSAPP+'?text='+encodeURIComponent(msg),'_blank'), 1800);
  }
  Object.keys(cart).forEach(k => delete cart[k]);
  document.getElementById('specialNote').value = '';
  buildOrderGrid(currentCatOrder);
  updateCartBar();
}

function closeSuccess() { document.getElementById('orderSuccess').style.display = 'none'; }

/* ══════════════════════════════════════
   TOAST
══════════════════════════════════════ */
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2200);
}

/* ══════════════════════════════════════
   SPLASH
══════════════════════════════════════ */
(function(){
  const s = document.getElementById('splashScreen');
  setTimeout(() => {
    s.classList.add('fade-out');
    setTimeout(() => { s.style.display='none'; goTo('screenMenu'); }, 800);
  }, 5000);
})();

fetchMenuFromSheet();
document.addEventListener('contextmenu', e => e.preventDefault());
</script>
