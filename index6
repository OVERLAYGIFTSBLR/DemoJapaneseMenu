<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no, viewport-fit=cover"/>
<title>さくら · Sakura Dining · AR Menu</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Noto+Serif+JP:wght@200;300;400;500&family=Noto+Sans+Devanagari:wght@300;400;500&family=Noto+Sans+Kannada:wght@300;400;500&family=Noto+Sans+Tamil:wght@300;400;500&family=Noto+Sans+Malayalam:wght@300;400;500&family=Noto+Sans+Telugu:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
<style>
:root {
  --ink:#050403; --ink2:#0D0B09; --ink3:#140F0B;
  --paper:#F2EAD8; --paper2:#E8DEC8;
  --beni:#7A2E1E; --beni2:#A03D28; --beni3:#C4513A; --beni4:#D4614A;
  --yama:#B8973A; --yama2:#D4AE52; --yama3:#EDD070;
  --jade:#2D5A3D; --jade2:#3D7A54;
  --ff-jp:'Noto Serif JP',serif;
  --ff-en:'Cormorant Garamond',serif;
  --ff-ui:'DM Sans',sans-serif;
  --ff-hi:'Noto Sans Devanagari',sans-serif;
  --ff-kn:'Noto Sans Kannada',sans-serif;
  --ff-ta:'Noto Sans Tamil',sans-serif;
  --ff-ml:'Noto Sans Malayalam',sans-serif;
  --ff-te:'Noto Sans Telugu',sans-serif;
  --radius:6px;
  --glow-beni: 0 0 40px rgba(160,61,40,0.3);
  --glow-yama: 0 0 30px rgba(212,174,82,0.2);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{height:100%;overflow:hidden}
body{
  width:100vw;height:100%;overflow:hidden;
  font-family:var(--ff-ui);
  background:var(--ink);
  color:var(--paper);
  -webkit-tap-highlight-color:transparent;
}

/* GRAIN OVERLAY */
body::before{
  content:'';position:fixed;inset:0;z-index:9997;pointer-events:none;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)' opacity='0.035'/%3E%3C/svg%3E");
  opacity:0.6;mix-blend-mode:overlay;
}

/* ── SPLASH ── */
#splash{
  position:fixed;inset:0;z-index:9999;
  background:radial-gradient(ellipse 120% 120% at 50% -20%, #1a0a06 0%, #050403 60%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  transition:opacity 1.2s cubic-bezier(0.4,0,0.2,1);
}
#splash.out{opacity:0;pointer-events:none}

.splash-mon{
  width:100px;height:100px;border-radius:50%;
  border:1px solid rgba(122,46,30,0.35);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:32px;position:relative;
  animation:monGlow 4s ease-in-out infinite;
}
@keyframes monGlow{0%,100%{box-shadow:0 0 0 0 rgba(122,46,30,0),inset 0 0 0 0 rgba(122,46,30,0)}50%{box-shadow:0 0 60px 12px rgba(122,46,30,0.12),inset 0 0 30px rgba(122,46,30,0.05)}}
.splash-mon::before{content:'';position:absolute;inset:-16px;border-radius:50%;border:1px solid rgba(122,46,30,0.1);animation:ringPulse 4s ease-in-out infinite 0.5s}
.splash-mon::after{content:'';position:absolute;inset:-28px;border-radius:50%;border:1px solid rgba(122,46,30,0.05);animation:ringPulse 4s ease-in-out infinite 1s}
@keyframes ringPulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.06);opacity:0.5}}
.s-title{
  font-family:var(--ff-en);font-size:58px;font-weight:300;
  letter-spacing:0.18em;
  background:linear-gradient(135deg,var(--paper) 0%,var(--yama2) 50%,var(--paper) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  animation:fadeUp 1s ease 0.3s both;
}
.s-jp{font-family:var(--ff-jp);font-size:11px;font-weight:200;letter-spacing:0.5em;color:rgba(122,46,30,0.65);margin-top:12px;animation:fadeUp 1s ease 0.5s both}
.s-tagline{font-size:9px;letter-spacing:0.35em;text-transform:uppercase;color:rgba(240,232,213,0.2);margin-top:18px;animation:fadeUp 1s ease 0.7s both}
.s-bar{position:absolute;bottom:52px;left:50%;transform:translateX(-50%);width:140px;animation:fadeUp 0.6s ease 1.2s both}
.s-bar-track{height:1px;background:rgba(240,232,213,0.06);border-radius:1px;overflow:hidden}
.s-bar-fill{height:1px;background:linear-gradient(90deg,transparent,var(--beni),var(--yama),var(--beni),transparent);width:0;animation:barFill 3.8s cubic-bezier(0.4,0,0.2,1) 0.6s forwards}
@keyframes barFill{to{width:100%}}
.s-bar-txt{text-align:center;font-size:8px;letter-spacing:0.3em;color:rgba(240,232,213,0.15);margin-top:12px;text-transform:uppercase}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* ── LAYOUT ── */
#app{position:fixed;inset:0;display:flex;overflow:hidden}

/* ── SIDE RAIL ── */
#sliderPanel{
  position:relative;z-index:100;
  width:44px;flex-shrink:0;
  display:flex;flex-direction:column;align-items:center;
  background:rgba(5,4,3,0.95);
  border-right:1px solid rgba(240,232,213,0.04);
  padding:calc(72px + env(safe-area-inset-top)) 0 calc(20px + env(safe-area-inset-bottom));
  touch-action:none;
  backdrop-filter:blur(20px);
}
.sp-label{
  font-family:var(--ff-jp);font-size:7px;font-weight:200;
  color:rgba(240,232,213,0.15);letter-spacing:0.25em;
  writing-mode:vertical-rl;margin:8px 0;
}
#sliderTrackWrap{flex:1;width:100%;position:relative;display:flex;align-items:center;justify-content:center;cursor:pointer;}
#sliderRail{position:absolute;left:50%;transform:translateX(-50%);width:1px;top:0;bottom:0;background:rgba(240,232,213,0.06);border-radius:1px}
#sliderFill{position:absolute;left:50%;transform:translateX(-50%);width:2px;top:0;height:0;background:linear-gradient(to bottom,var(--beni3),var(--beni));border-radius:1px;transition:height 0.04s linear;box-shadow:0 0 8px rgba(160,61,40,0.4)}
#sliderThumb{
  position:absolute;left:50%;transform:translate(-50%,0);top:0;
  width:32px;height:32px;border-radius:50%;
  background:radial-gradient(circle at 35% 30%,var(--beni3),var(--beni));
  border:1.5px solid rgba(240,232,213,0.2);
  box-shadow:0 0 20px rgba(160,61,40,0.5),0 2px 8px rgba(0,0,0,0.6),inset 0 1px 0 rgba(255,255,255,0.08);
  cursor:grab;display:flex;align-items:center;justify-content:center;
  transition:box-shadow 0.2s,transform 0.15s;z-index:2;
}
#sliderThumb.active{cursor:grabbing;box-shadow:0 0 30px rgba(196,81,58,0.7),0 4px 12px rgba(0,0,0,0.7);transform:translate(-50%,0) scale(1.12)}
#sliderThumb::after{content:'';width:4px;height:4px;border-radius:50%;background:rgba(240,232,213,0.5)}
#sliderTooltip{
  position:absolute;right:52px;
  background:rgba(5,3,2,0.92);
  border:1px solid rgba(240,232,213,0.08);
  border-radius:var(--radius);padding:6px 12px;
  white-space:nowrap;pointer-events:none;
  font-family:var(--ff-en);font-size:13px;color:var(--yama2);letter-spacing:0.06em;
  opacity:0;transition:opacity 0.2s;z-index:10;
  box-shadow:0 8px 32px rgba(0,0,0,0.5);
  backdrop-filter:blur(12px);
}
#sliderTooltip.show{opacity:1}

/* ── MAIN AREA ── */
#scrollArea{flex:1;overflow:hidden;position:relative;touch-action:pan-y;}
#cardTrack{position:absolute;top:0;left:0;right:0;will-change:transform}

/* ── HUD ── */
#hud{
  position:fixed;top:0;left:44px;right:0;z-index:50;
  padding:calc(12px + env(safe-area-inset-top)) 20px 12px;
  background:linear-gradient(to bottom,rgba(5,4,3,0.97) 0%,rgba(5,4,3,0.7) 70%,transparent 100%);
  display:flex;flex-direction:column;gap:8px;pointer-events:all;
  backdrop-filter:blur(0px);
}
.hud-row1{display:flex;align-items:center;justify-content:space-between;pointer-events:all}
.hud-brand{display:flex;align-items:baseline;gap:10px;}
.hud-brand-name{font-family:var(--ff-en);font-size:24px;font-weight:400;letter-spacing:0.12em}
.hud-brand-jp{font-family:var(--ff-jp);font-size:10px;font-weight:200;letter-spacing:0.3em;color:rgba(240,232,213,0.28)}
.hud-right{display:flex;align-items:center;gap:10px}
.hud-table{
  font-size:8.5px;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--yama2);border:1px solid rgba(184,151,58,0.2);
  border-radius:20px;padding:5px 12px;
  background:rgba(184,151,58,0.05);
}
.hud-cart-btn{
  width:40px;height:40px;border-radius:50%;
  background:rgba(240,232,213,0.06);
  border:1px solid rgba(240,232,213,0.1);
  display:flex;align-items:center;justify-content:center;
  font-size:17px;cursor:pointer;position:relative;
  transition:all 0.25s cubic-bezier(0.34,1.56,0.64,1);
}
.hud-cart-btn:hover{background:rgba(240,232,213,0.1);transform:scale(1.05)}
.hud-cart-btn:active{transform:scale(0.92)}
.hud-cart-count{
  position:absolute;top:-4px;right:-4px;
  width:18px;height:18px;border-radius:50%;
  background:linear-gradient(135deg,var(--beni3),var(--beni));
  border:2px solid var(--ink);font-size:8px;font-weight:600;
  color:var(--paper);display:none;align-items:center;justify-content:center;
  box-shadow:0 2px 8px rgba(122,46,30,0.5);
}
.hud-cart-count.show{display:flex}

/* ── LANG SWITCHER ── */
.lang-switcher{
  display:flex;align-items:center;gap:3px;
  background:rgba(5,3,2,0.8);
  border:1px solid rgba(240,232,213,0.07);
  border-radius:24px;padding:3px 5px;
  width:fit-content;overflow-x:auto;
  -webkit-overflow-scrolling:touch;scrollbar-width:none;
  backdrop-filter:blur(10px);
}
.lang-switcher::-webkit-scrollbar{display:none}
.lang-btn{
  font-size:9px;font-weight:400;letter-spacing:0.04em;
  padding:4px 9px;border-radius:16px;border:none;
  background:transparent;color:rgba(240,232,213,0.45);
  cursor:pointer;transition:all 0.22s;white-space:nowrap;
  font-family:var(--ff-ui);flex-shrink:0;
}
.lang-btn.active{
  background:linear-gradient(135deg,var(--beni3),var(--beni));
  color:#fff;
  box-shadow:0 2px 12px rgba(122,46,30,0.5);
}
.lang-btn:active{transform:scale(0.9)}

/* ── DISH CARDS ── */
.dish-card{width:100%;position:absolute;left:0;right:0;overflow:hidden;display:flex;flex-direction:column}

/* CARD BG */
.dish-bg{
  position:absolute;inset:0;z-index:0;
  background:
    radial-gradient(ellipse 70% 50% at 15% 25%, rgba(122,46,30,0.18) 0%, transparent 60%),
    radial-gradient(ellipse 60% 50% at 85% 75%, rgba(184,151,58,0.08) 0%, transparent 55%),
    radial-gradient(ellipse 100% 80% at 50% 100%, rgba(5,3,2,0.8) 0%, transparent 60%),
    var(--ink2);
}
.dish-bg::after{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(90deg, transparent, transparent 80px, rgba(240,232,213,0.007) 80px, rgba(240,232,213,0.007) 81px);
  pointer-events:none;
}

/* ── 3D VIEWER AREA ── */
.dish-viewer{position:relative;z-index:5;flex:1;overflow:hidden;min-height:0}
model-viewer{
  width:100%;height:100%;background:transparent;
  --poster-color:transparent;
  --progress-bar-color:rgba(196,81,58,0.4);
  --progress-mask:transparent;
}

/* ── FIX: Style the native model-viewer AR slot button ── */
model-viewer > button[slot="ar-button"] {
  display: none !important;
}

.viewer-no-model{
  position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:14px;
}
.viewer-no-emoji{font-size:96px;animation:floatEmoji 5s ease-in-out infinite;filter:drop-shadow(0 20px 40px rgba(0,0,0,0.5))}
@keyframes floatEmoji{
  0%,100%{transform:translateY(0) rotate(-3deg) scale(1)}
  50%{transform:translateY(-14px) rotate(3deg) scale(1.04)}
}
.viewer-no-txt{font-size:9px;letter-spacing:0.3em;text-transform:uppercase;color:rgba(240,232,213,0.15)}

/* CORNER ACCENTS */
.viewer-corner{position:absolute;z-index:10;pointer-events:none;width:22px;height:22px;transition:opacity 0.3s}
.viewer-corner.tl{top:12px;left:12px;border-top:1.5px solid rgba(122,46,30,0.6);border-left:1.5px solid rgba(122,46,30,0.6)}
.viewer-corner.tr{top:12px;right:12px;border-top:1.5px solid rgba(122,46,30,0.6);border-right:1.5px solid rgba(122,46,30,0.6)}
.viewer-corner.bl{bottom:12px;left:12px;border-bottom:1.5px solid rgba(122,46,30,0.6);border-left:1.5px solid rgba(122,46,30,0.6)}
.viewer-corner.br{bottom:12px;right:12px;border-bottom:1.5px solid rgba(122,46,30,0.6);border-right:1.5px solid rgba(122,46,30,0.6)}

/* VIEWER BADGE */
.viewer-badge{
  position:absolute;top:14px;left:50%;transform:translateX(-50%);z-index:10;
  display:flex;align-items:center;gap:7px;
  background:rgba(5,3,2,0.6);border:1px solid rgba(240,232,213,0.08);
  border-radius:30px;padding:5px 14px;pointer-events:none;
  backdrop-filter:blur(8px);
}
.vb-dot{width:5px;height:5px;border-radius:50%;background:var(--beni3);animation:blinkDot 2s ease infinite;box-shadow:0 0 6px var(--beni2)}
@keyframes blinkDot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.2;transform:scale(0.7)}}
.vb-txt{font-size:8px;letter-spacing:0.25em;text-transform:uppercase;color:rgba(240,232,213,0.4)}

/* PROGRESS RING on viewer */
.model-loader{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  display:none;flex-direction:column;align-items:center;gap:12px;pointer-events:none;z-index:20;
}
.loader-ring{
  width:36px;height:36px;
  border:1.5px solid rgba(122,46,30,0.12);
  border-top-color:var(--beni3);
  border-radius:50%;animation:spin 0.8s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}
.loader-txt{font-size:8px;letter-spacing:0.28em;text-transform:uppercase;color:rgba(240,232,213,0.2)}

/* ── SUMI DIVIDER ── */
.sumi-line{position:relative;z-index:10;padding:0 20px;flex-shrink:0}
.sumi-line svg{display:block;width:100%;height:10px}

/* ── DISH INFO ── */
.dish-info{
  position:relative;z-index:10;padding:10px 20px 0;flex-shrink:0;
  background:linear-gradient(to top,rgba(5,3,2,0.98) 0%,rgba(5,3,2,0.75) 100%);
}
.info-category{
  font-size:8px;letter-spacing:0.36em;text-transform:uppercase;
  color:var(--beni3);margin-bottom:5px;
  display:flex;align-items:center;gap:10px;
}
.info-category::before{content:'';width:20px;height:1px;background:linear-gradient(90deg,var(--beni2),transparent)}
.info-names{display:flex;align-items:baseline;gap:14px;margin-bottom:5px;flex-wrap:wrap}
.info-name-en{
  font-family:var(--ff-en);font-size:34px;font-weight:400;line-height:1;
  letter-spacing:0.03em;
  background:linear-gradient(135deg,var(--paper),var(--paper2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.info-name-native{font-size:19px;font-weight:300;color:rgba(240,232,213,0.65);line-height:1.2}
.info-desc{
  font-size:11px;font-weight:300;color:rgba(240,232,213,0.42);
  line-height:1.65;margin-bottom:10px;
  max-height:3.3em;overflow:hidden;
}
.info-meta{display:flex;align-items:center;gap:10px;margin-bottom:10px;flex-wrap:wrap}
.info-price{
  font-family:var(--ff-en);font-size:30px;font-weight:400;
  background:linear-gradient(135deg,var(--yama2),var(--yama3));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  letter-spacing:0.04em;
}
.info-pills{display:flex;gap:5px;flex-wrap:wrap}
.info-pill{font-size:8px;letter-spacing:0.12em;text-transform:uppercase;padding:3px 10px;border-radius:2px;font-weight:400}
.pill-veg{background:rgba(45,90,61,0.15);color:#98D4A3;border:1px solid rgba(45,90,61,0.35)}
.pill-chef{background:rgba(184,151,58,0.1);color:var(--yama3);border:1px solid rgba(184,151,58,0.25)}
.pill-new{background:rgba(27,65,110,0.15);color:#90CAF9;border:1px solid rgba(27,65,110,0.35)}

/* ── ACTION BAR ── */
.dish-actions{
  position:relative;z-index:10;
  padding:0 20px calc(14px + env(safe-area-inset-bottom));
  display:flex;gap:10px;align-items:stretch;flex-shrink:0;
  background:rgba(5,3,2,0.98);
}

/* ADD TO CART BUTTON */
.btn-add-cart{
  flex:1;position:relative;overflow:hidden;
  background:linear-gradient(135deg,var(--beni3) 0%,var(--beni) 60%,#621e10 100%);
  border:none;border-radius:var(--radius);padding:14px 14px;
  font-family:var(--ff-ui);font-size:12px;font-weight:500;letter-spacing:0.07em;
  color:var(--paper);cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:12px;
  box-shadow:0 4px 30px rgba(122,46,30,0.4),inset 0 1px 0 rgba(255,255,255,0.08);
  transition:all 0.25s cubic-bezier(0.34,1.56,0.64,1);
}
.btn-add-cart::before{
  content:'';position:absolute;top:0;left:-120%;width:60%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(240,232,213,0.15),transparent);
  animation:shimmer 3s ease-in-out infinite;
}
@keyframes shimmer{0%{left:-120%}50%,100%{left:140%}}
.btn-add-cart:hover{transform:translateY(-1px);box-shadow:0 8px 36px rgba(122,46,30,0.5),inset 0 1px 0 rgba(255,255,255,0.1)}
.btn-add-cart:active{transform:scale(0.97)}
.btn-add-cart.added-pulse{
  background:linear-gradient(135deg,#2a6e34,#1d5025);
  box-shadow:0 4px 30px rgba(45,110,52,0.45);
}
.btn-add-cart-icon{font-size:22px;line-height:1;flex-shrink:0}
.btn-add-cart-text{display:flex;flex-direction:column;align-items:flex-start;gap:2px}
.btn-add-cart-main{font-size:12px;font-weight:500}
.btn-add-cart-sub{font-size:8px;color:rgba(240,232,213,0.55);font-weight:300;letter-spacing:0.12em}
.btn-cart-counter{
  position:absolute;top:-2px;right:-2px;width:20px;height:20px;border-radius:50%;
  background:linear-gradient(135deg,var(--yama2),var(--yama3));
  border:2px solid var(--ink);font-size:9px;font-weight:700;
  color:var(--ink);display:none;align-items:center;justify-content:center;
}
.btn-cart-counter.show{display:flex}

/* ── AR BUTTON (FIXED) ── */
.btn-ar{
  width:56px;flex-shrink:0;
  background:rgba(240,232,213,0.05);
  border:1px solid rgba(240,232,213,0.12);
  border-radius:var(--radius);cursor:pointer;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;
  transition:all 0.25s cubic-bezier(0.34,1.56,0.64,1);
  position:relative;overflow:visible;
  padding:0;
}
.btn-ar::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(122,46,30,0.2),transparent);
  opacity:0;transition:opacity 0.3s;border-radius:var(--radius);
}
.btn-ar:hover::before{opacity:1}
.btn-ar:hover{
  border-color:rgba(196,81,58,0.5);
  background:rgba(196,81,58,0.08);
  box-shadow:0 0 20px rgba(122,46,30,0.25);
  transform:translateY(-1px);
}
.btn-ar:active{transform:scale(0.92)}

/* no-model: dimmed but still hoverable for tooltip */
.btn-ar.no-model{
  opacity:0.3;
  cursor:not-allowed;
}
.btn-ar.no-model:hover{
  transform:none;
  box-shadow:none;
  border-color:rgba(240,232,213,0.12);
  background:rgba(240,232,213,0.05);
}

/* AR not-available state */
.btn-ar.ar-unavailable{
  border-color:rgba(240,232,213,0.08);
}

.btn-ar-icon{
  display:flex;align-items:center;justify-content:center;
  color:rgba(240,232,213,0.75);
  position:relative;z-index:1;
}
.btn-ar-icon svg{width:22px;height:22px}
