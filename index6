const LANGS    = ['en','jp','hi','kn','ta','ml','te'];
const FONT_MAP = {en:'',jp:'var(--ff-jp)',hi:'var(--ff-hi)',kn:'var(--ff-kn)',ta:'var(--ff-ta)',ml:'var(--ff-ml)',te:'var(--ff-te)'};

