    ${nativeName?`<div class="info-name-native" style="${fs}">${nativeName}</div>`:''}
  </div>
  <div class="info-desc" style="${fs}font-size:${font?'12':'11'}px">${desc}</div>
  <div class="info-meta">
    <div class="info-price">₹ ${item.price.toLocaleString('en-IN')}</div>
    <div class="info-pills">${pills.join('')}</div>
  </div>
</div>
<div class="dish-actions">
  <button class="btn-add-cart" id="addCartBtn_${idx}" onclick="addToCart('${item.id}',${idx})">
    <div class="btn-cart-counter" id="cartCounter_${idx}">0</div>
    <div class="btn-add-cart-icon">🛒</div>
    <div class="btn-add-cart-text">
      <div class="btn-add-cart-main" style="${fs}">${t.addToCart}</div>
      <div class="btn-add-cart-sub">₹ ${item.price.toLocaleString('en-IN')} per item</div>
    </div>
  </button>

  <button
    class="btn-ar${has3d ? '' : ' no-model'}"
    id="arBtn_${idx}"
    onclick="${has3d ? `triggerAR(${idx})` : `showToast('📱 ' + T[currentLang].arNoModel)`}"
    title="${has3d ? 'View in Augmented Reality' : t.arNotAvail}">
    <div class="btn-ar-icon">${arSVG}</div>
    <span class="btn-ar-txt">${t.arBtn}</span>
    <div class="btn-ar-badge">${has3d ? t.tapAR : t.arNotAvail}</div>
  </button>
</div>`;

    track.appendChild(card);

    // Restore cart counters
    const cq = cart[item.id]||0;
    if(cq>0){const c=card.querySelector('#cartCounter_'+idx);if(c){c.textContent=cq;c.classList.add('show');}}

    // Model viewer events
    if (has3d) {
      const mv = card.querySelector('#mv_'+idx);
      const ld = card.querySelector('#loader_'+idx);
      if (mv && ld) {
        ld.style.display = 'flex';
        mv.addEventListener('load', ()=>{ ld.style.display='none'; }, {once:true});
        mv.addEventListener('error', ()=>{ ld.style.display='none'; }, {once:true});
        setTimeout(()=>{ if(ld) ld.style.display='none'; }, 18000);

        // Stop auto-rotate when user interacts
        mv.addEventListener('camera-change', ()=>{ if(mv.getAttribute('auto-rotate')!==null) mv.removeAttribute('auto-rotate'); });

        // AR status feedback
        mv.addEventListener('ar-status', (e)=>{
          const btn = document.getElementById('arBtn_' + idx);
          if (e.detail.status === 'failed') {
            showToast('📱 ' + T[currentLang].arNotAvail);
            if (btn) btn.classList.remove('ar-active');
          } else if (e.detail.status === 'session-started') {
            showToast('✨ AR mode active');
          } else if (e.detail.status === 'not-presenting') {
            if (btn) btn.classList.remove('ar-active');
          }
        });

        // Update AR button appearance once model-viewer knows AR support
        mv.addEventListener('load', () => {
          const btn = document.getElementById('arBtn_' + idx);
          if (btn && !mv.canActivateAR) {
            btn.classList.add('ar-unavailable');
            const badge = btn.querySelector('.btn-ar-badge');
            if (badge) badge.textContent = T[currentLang].arNotAvail;
          }
        }, {once: true});
      }
    }
  });
}

function buildMenu() {
  viewH = window.innerHeight;
  totalScrollH = (menuItems.length - 1) * viewH;
  buildCards(); initSliderDrag(); initScrollArea(); startRafLoop();
  setTimeout(()=>{
    document.getElementById('globalLoader').classList.add('hide');
    setTimeout(()=>{ document.getElementById('globalLoader').style.display='none'; },700);
    document.getElementById('app').style.display='flex';
  },300);
}

/* ══════════════════════════════════════════════
   RAF LOOP + SLIDER
══════════════════════════════════════════════ */
function startRafLoop() {
  function loop() {
    const diff = targetY - scrollY;
    scrollY += sliderDragging ? diff : diff * 0.1;
    if (Math.abs(diff) < 0.15) scrollY = targetY;
    scrollY = Math.max(0,Math.min(totalScrollH,scrollY));
    document.getElementById('cardTrack').style.transform = `translateY(${-scrollY}px)`;
    syncSliderVisual();
    requestAnimationFrame(loop);
  }
  requestAnimationFrame(loop);
}

function initSliderDrag() {
  const wrap=document.getElementById('sliderTrackWrap'),tooltip=document.getElementById('sliderTooltip');
  function prog(y){const r=wrap.getBoundingClientRect();return Math.max(0,Math.min(1,(y-r.top)/r.height));}
  function apply(p){
    targetY=p*totalScrollH;
    const idx=Math.min(menuItems.length-1,Math.round(p*(menuItems.length-1)));
    const item=menuItems[idx];
    tooltip.textContent=(idx+1)+' · '+(item?(currentLang==='jp'?(item.jp||item.name):item.name):'');
    tooltip.classList.add('show');clearTimeout(tooltipTimer);
  }
  function end(){sliderDragging=false;document.getElementById('sliderThumb').classList.remove('active');tooltipTimer=setTimeout(()=>tooltip.classList.remove('show'),1000);}
  wrap.addEventListener('pointerdown',e=>{sliderDragging=true;wrap.setPointerCapture(e.pointerId);document.getElementById('sliderThumb').classList.add('active');apply(prog(e.clientY));e.preventDefault();e.stopPropagation();});
  wrap.addEventListener('pointermove',e=>{if(!sliderDragging)return;apply(prog(e.clientY));e.preventDefault();e.stopPropagation();});
  wrap.addEventListener('pointerup',end);wrap.addEventListener('pointercancel',end);
}

function syncSliderVisual() {
  const p=totalScrollH>0?scrollY/totalScrollH:0;
  const wrap=document.getElementById('sliderTrackWrap'),thumb=document.getElementById('sliderThumb'),fill=document.getElementById('sliderFill');
  if(!wrap||!thumb)return;
  const usable=wrap.clientHeight-(thumb.clientHeight||32);
  const top=Math.max(0,Math.min(usable,p*usable));
  thumb.style.top=top+'px';
  fill.style.height=(top+(thumb.clientHeight||32)/2)+'px';
}

function initScrollArea() {
  const area=document.getElementById('scrollArea');
  let touchStartY=0,touchTargetY0=0,velY=0,lastTY=0,lastTTime=0,flingId=null,touchOnModel=false;

  area.addEventListener('touchstart',e=>{
    touchOnModel=!!e.target.closest('model-viewer');
    if(touchOnModel)return;
    cancelAnimationFrame(flingId);
    touchStartY=e.touches[0].clientY;touchTargetY0=targetY;
    velY=0;lastTY=touchStartY;lastTTime=Date.now();
  },{passive:true});

  area.addEventListener('touchmove',e=>{
    if(touchOnModel)return;
    const now=Date.now(),cy=e.touches[0].clientY;
    velY=(lastTY-cy)/((now-lastTTime)||1);lastTY=cy;lastTTime=now;
    targetY=Math.max(0,Math.min(totalScrollH,touchTargetY0+(touchStartY-cy)));
  },{passive:true});

  area.addEventListener('touchend',()=>{
    if(touchOnModel){touchOnModel=false;return;}
    let v=velY*16;
    function fling(){if(Math.abs(v)<0.3)return;targetY=Math.max(0,Math.min(totalScrollH,targetY+v));v*=0.9;flingId=requestAnimationFrame(fling);}
    flingId=requestAnimationFrame(fling);
  },{passive:true});

  area.addEventListener('wheel',e=>{e.preventDefault();targetY=Math.max(0,Math.min(totalScrollH,targetY+e.deltaY*1.1));},{passive:false});

  document.addEventListener('keydown',e=>{
    const s=viewH*0.75;
    if(e.key==='ArrowDown')targetY=Math.min(totalScrollH,targetY+s);
    if(e.key==='ArrowUp')targetY=Math.max(0,targetY-s);
  });
}

/* ══════════════════════════════════════════════
   CART & ORDER
══════════════════════════════════════════════ */
function addToCart(id,cardIdx) {
  const item=menuItems.find(i=>i.id===id);if(!item||!item.available)return;
  cart[id]=(cart[id]||0)+1;updateCartUI();
  const btn=document.getElementById('addCartBtn_'+cardIdx);
  if(btn){btn.classList.add('added-pulse');setTimeout(()=>btn.classList.remove('added-pulse'),750);}
  const c=document.getElementById('cartCounter_'+cardIdx);
  if(c){c.textContent=cart[id];c.classList.add('show');}
  showToast(item.emoji+' '+item.name+' '+T[currentLang].toastSuffix);
}

function updateCartUI() {
  const n=Object.values(cart).reduce((a,b)=>a+b,0);
  const el=document.getElementById('hudCartCount');el.textContent=n;el.classList.toggle('show',n>0);
}

function openOrder() {
  const body=document.getElementById('orderBody');body.innerHTML='';
  const t=T[currentLang];let total=0;
  const entries=Object.entries(cart).filter(([,q])=>q>0);
  if(!entries.length){
    body.innerHTML=`<div style="text-align:center;padding:60px 24px;color:rgba(240,232,213,0.25);font-family:var(--ff-en);font-size:20px;font-style:italic;">${t.empty}<br><small style="font-size:12px;font-family:var(--ff-jp);font-weight:200;letter-spacing:0.15em;display:block;margin-top:8px">${t.emptySub}</small></div>`;
  } else {
    entries.forEach(([id,qty])=>{
      const item=menuItems.find(i=>i.id===id);if(!item)return;
      const sub=item.price*qty;total+=sub;
      const row=document.createElement('div');row.className='order-item-row';
      row.innerHTML=`<div class="orow-emoji">${item.emoji}</div><div class="orow-info"><div class="orow-name">${item.name}</div><div class="orow-jp">${item.jp||''}</div><div class="orow-price">₹ ${sub.toLocaleString('en-IN')}</div></div><div class="orow-qty"><button class="qty-b" onclick="changeCartQty('${id}')">−</button><div class="qty-n">${qty}</div><button class="qty-b" onclick="addToCartDirect('${id}')">+</button></div>`;
      body.appendChild(row);
    });
  }
  document.getElementById('orderTotal').textContent='₹ '+total.toLocaleString('en-IN');
  document.getElementById('ordTitle').textContent=t.orderTitle;
  document.getElementById('ordSubtitle').textContent=t.orderSub;
  document.getElementById('ordTotalLabel').textContent=t.totalLabel;
  document.getElementById('placeBtn').textContent=t.sendBtn;
  document.getElementById('screenOrder').classList.add('show');
}

function closeOrder(){document.getElementById('screenOrder').classList.remove('show');}
function changeCartQty(id){if(!cart[id])return;cart[id]--;if(cart[id]<=0)delete cart[id];updateCartUI();syncCounters();openOrder();}
function addToCartDirect(id){cart[id]=(cart[id]||0)+1;updateCartUI();syncCounters();openOrder();}

function syncCounters(){
  menuItems.forEach((item,idx)=>{
    const c=document.getElementById('cartCounter_'+idx);if(!c)return;
    const q=cart[item.id]||0;c.textContent=q;c.classList.toggle('show',q>0);
  });
}

function placeOrder() {
  const entries=Object.entries(cart).filter(([,q])=>q>0);if(!entries.length)return;
  const note=document.getElementById('specialNote').value.trim();
  let total=0;const snap=[];
  entries.forEach(([id,qty])=>{const item=menuItems.find(i=>i.id===id);if(!item)return;snap.push({item,qty});total+=item.price*qty;});
  const orderId='#ORD-'+Math.floor(1000+Math.random()*9000);
  const now=new Date();
  const time=now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:true});
  const date=now.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
  let lines='';snap.forEach(({item,qty})=>{lines+=item.name.padEnd(18)+' ×'+qty+'  ₹'+(item.price*qty).toLocaleString('en-IN')+'\n';});
  const msg=`🍽️ *NEW ORDER — KOT*\n━━━━━━━━━━━━━━━━━━\n*Table  :* ${TABLE_NUMBER}\n*Seat   :* ${TABLE_INFO}\n*Order  :* ${orderId}\n*Time   :* ${time}, ${date}\n━━━━━━━━━━━━━━━━━━\n${lines}━━━━━━━━━━━━━━━━━━\n*TOTAL  :* ₹${total.toLocaleString('en-IN')}\n━━━━━━━━━━━━━━━━━━${note?'\n📝 *Note:* '+note:''}\n_Sent via Sakura AR Menu · さくら_`;
  let preview='';snap.forEach(({item,qty})=>{preview+=item.name+' × '+qty+'  ₹'+(item.price*qty).toLocaleString('en-IN')+'\n';});
  preview+='\n合計: ₹'+total.toLocaleString('en-IN');
  if(note) preview+='\n📝 '+note;
  document.getElementById('kotBody').textContent=preview;
  closeOrder();
  document.getElementById('successOverlay').classList.add('show');
  setTimeout(()=>window.open('https://wa.me/'+KITCHEN_WA+'?text='+encodeURIComponent(msg),'_blank'),500);
  Object.keys(cart).forEach(k=>delete cart[k]);
  document.getElementById('specialNote').value='';
  updateCartUI();syncCounters();
}

function closeSuccess(){document.getElementById('successOverlay').classList.remove('show');}

function showToast(msg) {
  const t=document.getElementById('toast');t.textContent='✓ '+msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2800);
}

/* ══════════════════════════════════════════════
   WAITER WIDGET
══════════════════════════════════════════════ */
const WC_ACTIONS=[
  {key:'waiter',emoji:'🙋',delayMs:0},
  {key:'water', emoji:'💧',delayMs:55},
  {key:'bill',  emoji:'🧾',delayMs:110},
  {key:'tissues',emoji:'🧻',delayMs:165},
  {key:'chair', emoji:'🪑',delayMs:220},
];
let wcOpen=false;
const wcCooldown={};

function buildWaiterMenu() {
  const t=T[currentLang];
  const menu=document.getElementById('wcMenu');menu.innerHTML='';
  WC_ACTIONS.forEach(action=>{
    const div=document.createElement('div');div.className='wc-option';
    div.style.animationDelay=action.delayMs+'ms';
    const labelKey='wc'+action.key.charAt(0).toUpperCase()+action.key.slice(1);
    const label=t[labelKey]||action.key;
    div.innerHTML=`<div class="wc-option-label">${label}</div><div class="wc-option-icon">${action.emoji}</div>`;
    div.onclick=()=>wcSend(action.key);
    menu.appendChild(div);
  });
}

function wcToggle(){
  wcOpen=!wcOpen;
  document.getElementById('wcMenu').classList.toggle('hidden',!wcOpen);
  document.getElementById('wcTrigger').classList.toggle('open',wcOpen);
  document.getElementById('wcIcon').textContent=wcOpen?'✕':'🔔';
  document.getElementById('wcPulse').style.display=wcOpen?'none':'block';
}

function wcSend(key){
  const t=T[currentLang];const now=Date.now();
  if(wcCooldown[key]&&(now-wcCooldown[key])<60000){wcShowToast(t.wcCooldown);return;}
  wcCooldown[key]=now;
  const action=WC_ACTIONS.find(a=>a.key===key);
  const labelKey='wc'+key.charAt(0).toUpperCase()+key.slice(1);
  const msgKey=labelKey+'Msg';
  const label=t[labelKey]||key;const msgBody=t[msgKey]||label;
  const time=new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:true});
  const waMsg=`🔔 *STAFF REQUEST*\n━━━━━━━━━━━━━━━\n*${action.emoji} ${label}*\n*Table :* ${TABLE_NUMBER}\n*Time  :* ${time}\n━━━━━━━━━━━━━━━\n${msgBody} Table ${TABLE_NUMBER}\n_Sakura AR Menu · さくら_`;
  window.open('https://wa.me/'+KITCHEN_WA+'?text='+encodeURIComponent(waMsg),'_blank');
  wcShowToast(action.emoji+' '+t.wcSentPrefix+' 📲');
  wcToggle();
}

function wcShowToast(msg){
  const t=document.getElementById('wcToast');t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3400);
}

/* ══════════════════════════════════════════════
   INIT
══════════════════════════════════════════════ */
window.addEventListener('load', async () => {
  try {
    await fetchMenu();
  } catch(e) {
    menuItems=FALLBACK;
    buildMenu();
  }
  buildWaiterMenu();

  setTimeout(()=>{
    const splash=document.getElementById('splash');
    splash.classList.add('out');
    setTimeout(()=>splash.style.display='none',1300);
  },2800);
});

window.addEventListener('resize', ()=>{
  viewH=window.innerHeight;
  totalScrollH=(menuItems.length-1)*viewH;
  buildCards();
});
</script>
