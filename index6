/* ══════════════════════════════════════════════
   LANGUAGE
══════════════════════════════════════════════ */
function setLang(lang) {
  currentLang = lang;
  const t = T[lang];
  LANGS.forEach(l=>document.getElementById('lb-'+l).classList.toggle('active',l===lang));
  document.getElementById('app').setAttribute('data-lang',lang);
  document.getElementById('ordTitle').textContent      = t.orderTitle;
  document.getElementById('ordSubtitle').textContent   = t.orderSub;
  document.getElementById('ordTotalLabel').textContent = t.totalLabel;
  document.getElementById('placeBtn').textContent      = t.sendBtn;
  document.getElementById('specialNote').placeholder   = t.specialPlaceholder;
  document.getElementById('waNoteTxt').textContent     = t.waNote;
  document.getElementById('waNoteSubTxt').textContent  = t.waNoteSubT;
  document.getElementById('successTitle').textContent  = t.successTitle;
  document.getElementById('successSub').textContent    = t.successSub;
  document.getElementById('successDoneBtn').textContent= t.successDone;
  buildCards();
  buildWaiterMenu();
}

function getDesc(item)       { return (item.desc&&item.desc[currentLang])?item.desc[currentLang]:(item.desc?.en||item.description||''); }
function getNativeName(item) { if(currentLang==='en')return ''; if(currentLang==='jp')return item.jp||''; return(item.names&&item.names[currentLang])?item.names[currentLang]:''; }
function getFont()           { return FONT_MAP[currentLang]||''; }

/* ══════════════════════════════════════════════
   FETCH MENU
══════════════════════════════════════════════ */
async function fetchMenu() {
  try {
    const res  = await fetch(SHEET_URL);
    const text = await res.text();
    const m    = text.match(/google\.visualization\.Query\.setResponse\(([\s\S]*?)\);/);
    if (!m) throw 0;
    const json = JSON.parse(m[1]);
    const cols = json.table.cols.map(c=>c.label.toLowerCase().trim());
    const get  = (r,col)=>{const i=cols.indexOf(col);return(i>=0&&r.c[i]&&r.c[i].v!=null)?String(r.c[i].v).trim():'';};
    const raw  = json.table.rows.filter(r=>r&&r.c).map((r,i)=>({
      id:get(r,'id')||'i'+i,name:get(r,'name'),jp:get(r,'jp_name'),
      names:{},desc:{en:get(r,'description')},description:get(r,'description'),
      category:get(r,'category'),price:parseInt(get(r,'price'))||0,emoji:get(r,'emoji')||'🍽️',
      veg:get(r,'veg').toLowerCase()==='yes',chef_pick:get(r,'chef_pick').toLowerCase()==='yes',
      new:get(r,'new').toLowerCase()==='yes',available:get(r,'available').toLowerCase()!=='no',
      glb_url:get(r,'glb_url'),
    })).filter(i=>i.name);
    raw.forEach(item=>{const fb=FALLBACK.find(f=>f.name===item.name);if(fb){item.names=fb.names||{};item.desc=fb.desc||{en:item.description};}});
    menuItems = raw;
  } catch(e) { menuItems = FALLBACK; }
  buildMenu();
}

/* ══════════════════════════════════════════════
   AR TRIGGER — FIXED
   Uses model-viewer's canActivateAR property to
   check support before calling activateAR().
   Falls back to a helpful toast on unsupported devices.
══════════════════════════════════════════════ */
function triggerAR(idx) {
  const t  = T[currentLang];
  const mv = document.getElementById('mv_' + idx);

  if (!mv) {
    showToast('📱 ' + t.arNoModel);
    return;
  }

  // model-viewer exposes canActivateAR = true only when
  // the browser/device supports WebXR or Quick Look AR
  if (mv.canActivateAR) {
    showToast('✨ ' + t.arLaunching);
    const btn = document.getElementById('arBtn_' + idx);
    if (btn) { btn.classList.add('ar-active'); setTimeout(()=>btn.classList.remove('ar-active'), 3000); }
    mv.activateAR();
  } else {
    showToast('📱 ' + t.arNotAvail);
  }
}

